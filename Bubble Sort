#include<iostream>
#include<stdio.h>
using namespace std;
int main()
{
    int i,j,temp,arr[] = {10,20,30,40,50};
    
    // Bubble Sorting.
    for(i=0; i<5-1; i++)
    {
        for(j=0; j<5-i-1; j++)
        {
            if (arr[j] > arr[j+1])
            {
                temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
    }
    
    //printing array.
    for (i=0; i<5; i++)
    {
        printf("%d ",arr[i]);
    }
    
    return 0;
}
