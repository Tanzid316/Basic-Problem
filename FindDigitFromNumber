#include<iostream>
using namespace std;

int main()
{
    int n,digit,count=0,sum=0;
    cout<<"Enter the number : ";
    cin>>n;

    while(n>0)
    {
        digit = n%10;
        cout<<digit<<endl;
        n = n/10;
        count++;
        sum = sum+digit;
    }

    cout<<"Total Digit : "<<count<<endl;
    cout<<"Total Sum = "<<sum<<endl;
    return 0;
}
